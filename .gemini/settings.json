    },
    "telegram": {
      "command": "npx",
      "args": [
        "-y",
        "@overpod/mcp-telegram"
      ],
      "env": {
        "TELEGRAM_API_ID": "36775136",
        "TELEGRAM_API_HASH": "35bba3e8501aa6c323f78a05f95c8dbf"
      }
    },
    "browser": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "/home/henriquejfp/.cache/ms-playwright",
        "PLAYWRIGHT_MCP_HEADLESS": "true",
        "PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS": "true"
      }
