# ========================================
# CONTACOMIGO - Variáveis de Ambiente
# ========================================

# --- BOT TELEGRAM ---
TELEGRAM_TOKEN=seu_token_aqui

# --- IA / GEMINI ---
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL_NAME=gemini-1.5-flash

# --- GOOGLE SEARCH ---
GOOGLE_API_KEY=sua_chave_google_aqui
GOOGLE_CSE_ID=seu_cse_id_aqui

# --- BANCO DE DADOS ---
# PostgreSQL (Railway/Produção)
DATABASE_URL=postgresql://usuario:senha@host:porta/database

# --- GOOGLE VISION / OCR ---
GOOGLE_APPLICATION_CREDENTIALS=credenciais/google_vision_credentials.json

# --- EMAIL (Relatórios) ---
SENDER_EMAIL=seu_email@gmail.com
EMAIL_HOST_USER=seu_email@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_app_google
EMAIL_RECEIVER=email_destino@gmail.com

# --- PIX (Doações) ---
PIX_KEY=sua_chave_pix_aqui

# --- PLUGGY / OPEN FINANCE ---
PLUGGY_CLIENT_ID=seu_client_id_pluggy
PLUGGY_CLIENT_SECRET=seu_client_secret_pluggy

# 🔐 WHITELIST OPEN FINANCE (Opcional)
# Lista de IDs do Telegram autorizados a usar Open Finance
# Formato: IDs separados por vírgula (sem espaços)
# Deixe vazio para permitir TODOS os usuários
# Exemplo: PLUGGY_WHITELIST=6157591255,123456789,987654321
PLUGGY_WHITELIST=

# ========================================
# COMO OBTER SEU TELEGRAM ID:
# 1. Envie /start para @userinfobot no Telegram
# 2. Copie o número que aparece em "Id: XXXXXXX"
# 3. Cole em PLUGGY_WHITELIST acima
# ========================================

# ========================================
# LICENÇA ACADÊMICA PLUGGY:
# - Trial: 14 dias gratuitos
# - Após trial: configure PLUGGY_WHITELIST com seu ID
# - Envie email para Pluggy solicitando licença acadêmica
# - Argumente: projeto acadêmico, uso limitado (1 CPF, 3-4 conexões)
# ========================================